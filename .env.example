APP_ENV=dev
LOG_LEVEL=INFO
TZ=Asia/Yakutsk

DATABASE_URL=sqlite+aiosqlite:///data/classifieds.sqlite3

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_DIGEST_CHAT_ID=

SOURCE_AYKHAL_ENABLED=true
TARGET_CITIES=Aykhal,Udachny
RUN_HOURS_LOCAL=09:00,14:00,18:00,22:00

REQUEST_TIMEOUT_SECONDS=20
REQUEST_RETRIES=2
EXISTING_BACKFILL_PER_RUN=10
RUN_ONCE_SEND_DELIVERY=true

TG_API_ID=
TG_API_HASH=
TG_SESSION_NAME=classifieds_hub_session
TG_SOURCE_CHATS=uda4niy
TG_BACKFILL_DAYS=30
TG_FETCH_LIMIT_PER_RUN=30
TG_MAX_MESSAGES_PER_RUN=300
TG_DELAY_SECONDS=1.2
TG_STRICT_CLASSIFICATION=true
